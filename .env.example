# ============================================
# AI20K‑162 — Task‑Planner Agent · Environment
# ============================================
# Copy file này thành .env và điền giá trị thật. KHÔNG commit .env!
#   cp .env.example .env

# ---- LLM provider: "gemini" (cloud, mặc định) | "ollama" (local) ----
# Đặt =ollama để chạy agent bằng model local trên máy này (không tốn quota).
# LƯU Ý: agent CHỈ hỗ trợ "gemini" hoặc "ollama" — KHÔNG dùng OpenAI/GPT
# (src/services/llm.py không có nhánh OpenAI; đặt OPENAI_API_KEY ở đây vô tác dụng).
LLM_PROVIDER=gemini

# ---- LLM: Google Gemini (function-calling) — chỉ dùng khi LLM_PROVIDER=gemini ----
# Lấy key miễn phí ở Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
MODEL_NAME=gemini-2.0-flash
LLM_TEMPERATURE=0.2

# ---- LLM: Ollama (local) — chỉ dùng khi LLM_PROVIDER=ollama ----
# langchain-ollama đã có sẵn trong requirements.txt.
# Cài Ollama (Windows: winget install Ollama.Ollama), rồi: ollama pull qwen2.5:7b && ollama serve
# Model PHẢI hỗ trợ tool-calling (qwen2.5, llama3.1) vì agent dùng bind_tools.
# Máy yếu RAM có thể đổi sang qwen2.5:3b.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---- App ----
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000,http://localhost:5173

# ---- Agent loop caps (chống treo) ----
MAX_STEPS=40
MAX_REPLANS=5

# ---- AI Logs (Deliverable #4) ----
# LangSmith — bật để có trace prompt + tool calls
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=ai20k-162-agent
LANGCHAIN_TRACING_V2=true
# Hook log do BTC cấp (giữ nguyên — dùng chung)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log

# ---- Ghi chú ----
# v1 KHÔNG dùng Database / Vector store (agent planning + tool-use, không phải RAG).
# Nếu sau này cần, thêm biến ở đây và khai báo trong src/config.py.
